-- CONFIG KLASÖR SİSTEMİ
local ConfigFolder = "VanillaHub_Configs"
if makefolder and not isfolder(ConfigFolder) then pcall(function() makefolder(ConfigFolder) end) end

local function GetSavedConfigs()
    local list = {}
    pcall(function()
        if listfiles and isfolder and isfolder(ConfigFolder) then
            for _, file in ipairs(listfiles(ConfigFolder)) do
                if file:match("%.json$") then
                    local name = file:match("([^/\\]+)%.json$")
                    if name then table.insert(list, name) end
                end
            end
        end
    end)
    if #list == 0 then return {"Bulunamadi"} end
    return list
end

