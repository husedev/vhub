                Config[k] = val
                
                -- SİHRİN OLDUĞU YER: Arayüzdeki Şalterleri ve Renkleri Görsel Olarak Güncelle
                if Flags[k] then
                    pcall(function()
                        Flags[k]:SetValue(val)
                    end)
                end
            end
            Fluent:Notify({Title="VanillaHub", Content="Arayüz ve Ayarlar Yüklendi!", Duration=3})
        else
            Fluent:Notify({Title="Hata", Content="Config dosyası okunamadı.", Duration=3})
        end
    end
end})

