-- AMBIENT & FOG MOTORU (HEPSİ BAĞIMSIZ HALE GETİRİLDİ)
local OrigLighting = {Ambient = Lighting.Ambient, OutdoorAmbient = Lighting.OutdoorAmbient, ClockTime = Lighting.ClockTime, Brightness = Lighting.Brightness, FogEnd = Lighting.FogEnd, FogColor = Lighting.FogColor, GlobalShadows = Lighting.GlobalShadows}

RunService.RenderStepped:Connect(function()
    -- Ortam Rengi
    if Config.AmbientEnabled then
        Lighting.Ambient = Config.Ambient 
        Lighting.OutdoorAmbient = Config.Ambient 
        Lighting.ColorShift_Top = Config.Ambient
    else
        Lighting.Ambient = OrigLighting.Ambient 
        Lighting.OutdoorAmbient = OrigLighting.OutdoorAmbient 
        Lighting.ColorShift_Top = Color3.fromRGB(0, 0, 0)
    end
    
    -- Zaman ve Parlaklık
    if Config.TimeEnabled then Lighting.ClockTime = Config.Time else Lighting.ClockTime = OrigLighting.ClockTime end
    if Config.BrightnessEnabled then Lighting.Brightness = Config.BrightnessValue else Lighting.Brightness = OrigLighting.Brightness end
    
    -- Sis Kontrolü
    if Config.FogEnabled then 
        Lighting.FogEnd = Config.FogEnd 
        Lighting.FogColor = Config.FogColor 
    else 
        Lighting.FogEnd = OrigLighting.FogEnd
        Lighting.FogColor = OrigLighting.FogColor 
    end
    
    -- Gölgeler
    if Config.DisableShadows then Lighting.GlobalShadows = false else Lighting.GlobalShadows = OrigLighting.GlobalShadows end
end)

-- SMART RAYCAST FONKSİYONU (DUVAR KONTROLÜ)
local function IsPlayerVisible(targetPlayer)
    if not targetPlayer.Character then return false end
    local head = targetPlayer.Character:FindFirstChild("Head") or targetPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not head then return false end

    local origin = CurrentCamera.CFrame.Position
    local direction = head.Position - origin
    local ignoreList = {LocalPlayer.Character, targetPlayer.Character}
    
    for i = 1, 5 do
        local rayParams = RaycastParams.new()
        rayParams.FilterDescendantsInstances = ignoreList
        rayParams.FilterType = Enum.RaycastFilterType.Exclude
        rayParams.IgnoreWater = true
        
        local result = workspace:Raycast(origin, direction, rayParams)
        if not result then return true end 
        
        local hit = result.Instance
        if hit.Transparency >= 0.8 or not hit.CanCollide then
            table.insert(ignoreList, hit) 
        else
            return false 
        end
    end
    return false
end

-- Aimbot Hedef Bulucu
local function GetAimPart(character)
    if Config.AimPart == "Head" then return character:FindFirstChild("Head")
    elseif Config.AimPart == "Torso" then return character:FindFirstChild("Torso") or character:FindFirstChild("UpperTorso")
    end return character:FindFirstChild("Head")
end

local FOVCircle
if Drawing then pcall(function() FOVCircle = Drawing.new("Circle") FOVCircle.Thickness = 1.5 FOVCircle.Color = Color3.fromRGB(255, 100, 70) FOVCircle.Filled = false FOVCircle.Visible = false end) end
local currentAngle = 0
local CurrentTargetPart = nil 

RunService:BindToRenderStep("VH_CoreEngine", Enum.RenderPriority.Camera.Value + 1, function()
    if not CurrentCamera then return end
    local char = LocalPlayer.Character

    if char and Config.Mevlana then
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if hrp then
            currentAngle = (currentAngle + math.rad(Config.MevlanaSpeed * 1.8)) % (math.pi * 2)
            hrp.CFrame = CFrame.new(hrp.Position) * CFrame.Angles(0, currentAngle, 0)
        end
    end

    if Config.Aimbot then
        local isAimKeyDown = UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton1) or UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton2)
        if isAimKeyDown then
            local targetInvalid = not CurrentTargetPart or not CurrentTargetPart:IsDescendantOf(workspace)
            if CurrentTargetPart and CurrentTargetPart.Parent and CurrentTargetPart.Parent:FindFirstChild("Humanoid") then
                if CurrentTargetPart.Parent.Humanoid.Health <= 0 then targetInvalid = true end
            end

            if targetInvalid then
                local closest = nil local dist = Config.TargetFOV
                for _, p in pairs(Players:GetPlayers()) do
                    if p ~= LocalPlayer and p.Character then
                        local targetPart = GetAimPart(p.Character)
                        if targetPart then
                            local pos, on = CurrentCamera:WorldToViewportPoint(targetPart.Position)
                            if on then
                                local d = (Vector2.new(pos.X, pos.Y) - UserInputService:GetMouseLocation()).Magnitude
                                if d < dist then dist = d closest = targetPart end
                            end
                        end
                    end
                end
                CurrentTargetPart = closest
            end
            if CurrentTargetPart then CurrentCamera.CFrame = CFrame.lookAt(CurrentCamera.CFrame.Position, CurrentTargetPart.Position) end
        else CurrentTargetPart = nil end
    end

    if FOVCircle then pcall(function() FOVCircle.Visible = Config.Aimbot FOVCircle.Radius = Config.TargetFOV FOVCircle.Position = UserInputService:GetMouseLocation() end) end

    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer then
            pcall(function()
                if p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                    if Config.ESP then
                        local finalColor = IsPlayerVisible(p) and Config.VisibleColor or Config.WallColor
                        
                        local high = p.Character:FindFirstChild("VH_ESP")
                        if not high then
                            high = Instance.new("Highlight") high.Name = "VH_ESP"
                            high.FillTransparency = 0.4 high.OutlineTransparency = 0.2 
                            high.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
                            high.Parent = p.Character
                        end
                        high.Adornee = p.Character high.FillColor = finalColor high.OutlineColor = finalColor
                    else
                        if p.Character and p.Character:FindFirstChild("VH_ESP") then p.Character.VH_ESP:Destroy() end
                    end
                end
            end)
        end
    end
end)

